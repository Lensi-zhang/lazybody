<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Map Layer (Bottom) -->
        <include
            layout="@layout/main_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="?attr/actionBarSize" />

        <!-- Top Bar Layer -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorSurface"
                app:titleTextColor="?attr/colorOnSurface"
                app:navigationIconTint="?attr/colorOnSurface"
                android:theme="@style/ToolbarTheme"
                app:title="@string/app_name"
                app:popupTheme="@style/AppTheme.PopupOverlay" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Search Results Layer (Overlay) -->
        <LinearLayout
            android:id="@+id/search_linear"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:visibility="gone"
            android:orientation="vertical"
            android:layout_marginTop="?attr/actionBarSize"
            android:elevation="12dp">
            <ListView
                android:id="@+id/search_list_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="?attr/colorOutlineVariant"
                android:dividerHeight="0.5dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/search_history_linear"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:visibility="gone"
            android:orientation="vertical"
            android:layout_marginTop="?attr/actionBarSize"
            android:elevation="12dp">
            <ListView
                android:id="@+id/search_history_list_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="?attr/colorOutlineVariant"
                android:dividerHeight="0.5dp"/>
        </LinearLayout>

        <!-- Boundary Radius Slider -->
        <LinearLayout
            android:id="@+id/boundary_slider_layout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="120dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="88dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:background="@drawable/boundary_slider_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tv_boundary_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="活动半径: 100米"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/seekBarBoundary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="10"
                android:max="1000"
                android:progress="100"
                android:progressTint="#2E7D32"
                android:thumbTint="#2E7D32" />
        </LinearLayout>

        <!-- Transparent overlay to catch clicks outside slider -->
        <View
            android:id="@+id/boundary_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@android:color/transparent" />

        <!-- FAB Layer (Top) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/faBtnBoundary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="120dp"
            android:contentDescription="@null"
            style="@style/Widget.Material3.FloatingActionButton.Secondary"
            app:srcCompat="@drawable/ic_boundary" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/faBtnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="48dp"
            android:contentDescription="@null"
            style="@style/Widget.Material3.FloatingActionButton.Primary"
            app:srcCompat="@drawable/ic_position" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>